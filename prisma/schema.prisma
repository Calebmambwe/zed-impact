// ZedImpact — Prisma Schema
// Multi-tenant nonprofit management platform

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ══════════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════════

enum ContactType {
  DONOR
  VOLUNTEER
  SPONSOR
  STAFF
  BOARD
  OTHER
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  DECEASED
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum EmailSendStatus {
  QUEUED
  SENT
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// Donation & Payment enums
enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum DonationType {
  ONE_TIME
  RECURRING
  IN_KIND
  MATCHING
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  CHECK
  CASH
  OTHER
}

enum PaymentGateway {
  STRIPE
  DPO_GROUP
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum CampaignType {
  DONATION
  EVENT
  RAFFLE
  AUCTION
  P2P
  MEMBERSHIP
  EMERGENCY
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ── Events, Store & Membership enums ─────────────────────────────────────────

enum EventType {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum MembershipInterval {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

// ── Sponsorship domain enums ──────────────────────────────────────────────────

enum SponsorshipStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SchoolType {
  PRIMARY
  SECONDARY
  TERTIARY
  VOCATIONAL
}

enum ChildUpdateType {
  GENERAL
  ACADEMIC
  HEALTH
  PHOTO
  LETTER
}

enum ChildDocumentType {
  BIRTH_CERTIFICATE
  PHOTO
  SCHOOL_REPORT
  MEDICAL
  OTHER
}

enum LetterDirection {
  SPONSOR_TO_CHILD
  CHILD_TO_SPONSOR
}

enum LetterStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  DELIVERED
}

enum ProgressStatus {
  SUBMITTED
  REVIEWED
}

// ══════════════════════════════════════════════════════════════════
// TENANCY & USERS
// ══════════════════════════════════════════════════════════════════

model Organization {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  description      String?
  logoUrl          String?
  website          String?
  planTier         PlanTier      @default(FREE)
  stripeAccountId  String?
  stripeCustomerId String?
  clerkOrgId       String?       @unique
  customDomain     String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  members       OrgMember[]
  apiKeys       OrgApiKey[]
  customDomains CustomDomain[]
  featureFlags  FeatureFlag[]
  auditLogs     AuditLog[]

  // Stub relations for future milestones
  contacts        Contact[]
  donations       Donation[]
  campaigns       Campaign[]
  donationForms   DonationForm[]
  events          Event[]
  eventRegistrations EventRegistration[]
  children        Child[]
  sponsorships    Sponsorship[]
  tags            Tag[]
  notes           Note[]
  segments        Segment[]
  emailCampaigns    EmailCampaign[]
  emailSends        EmailSend[]
  emailLogs         EmailLog[]
  emailPreferences  EmailPreference[]
  subscribers       Subscriber[]
  notifications     Notification[]
  milestones        MilestoneNotification[]
  contactActivities ContactActivity[]
  payments          Payment[]
  products        Product[]
  orders          Order[]
  membershipTiers MembershipTier[]
  memberships     Membership[]
  p2pFundraisers  P2PFundraiser[]
  raffleBundles   RaffleBundle[]
  auctionItems    AuctionItem[]
  donorTributes   DonorTribute[]
  giftMatches     GiftMatch[]
  fundraisingPages FundraisingPage[]
  staffTasks      StaffTask[]
  buildingProjects BuildingProject[]
  budgets         Budget[]
  impactReports   ImpactReport[]
  programs        Program[]
  schools         School[]
  letters         Letter[]
  sponsorMessages SponsorMessage[]
  childUpdates    ChildUpdate[]
  childDocuments  ChildDocument[]
  healthRecords   ChildHealthRecord[]
  academicTerms   AcademicTerm[]
  studentProgress StudentProgress[]
  teacherProfiles TeacherProfile[]
  sponsorWaitlist SponsorWaitlist[]
  childAuditLogs  ChildAuditLog[]
}

model User {
  id               String     @id @default(cuid())
  clerkId          String     @unique
  email            String     @unique
  name             String?
  avatarUrl        String?
  role             Role       @default(USER)
  stripeCustomerId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orgMemberships  OrgMember[]
  auditLogs       AuditLog[]
  notes           Note[]
  notifications   Notification[]
  sponsorships    Sponsorship[]
  teacherProfiles TeacherProfile[]
}

model OrgMember {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole   @default(STAFF)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrgApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CustomDomain {
  id             String    @id @default(cuid())
  organizationId String
  domain         String    @unique
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  enabled        Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════════
// STUB MODELS — Future milestones extend these
// Each has the minimum fields required for the tenant middleware.
// ══════════════════════════════════════════════════════════════════

model Contact {
  id              String         @id @default(cuid())
  organizationId  String
  userId          String?
  firstName       String
  lastName        String
  email           String?
  phone           String?
  type            ContactType    @default(DONOR)
  status          ContactStatus  @default(ACTIVE)
  address         String?
  city            String?
  country         String?
  notes           String?
  lifetimeValue   Float          @default(0)
  lastDonationAt  DateTime?
  customFields    Json?
  householdId     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  household        Contact?          @relation("HouseholdMembers", fields: [householdId], references: [id])
  householdMembers Contact[]         @relation("HouseholdMembers")
  contactTags      ContactTag[]
  contactNotes     Note[]
  activity         ContactActivity[]
  emailPreference  EmailPreference?
  emailSends       EmailSend[]
  milestones       MilestoneNotification[]
  donations        Donation[]

  @@index([organizationId])
  @@index([email])
  @@index([type])
  @@index([status])
  @@index([householdId])
}

model Donation {
  id                     String          @id @default(cuid())
  organizationId         String
  userId                 String?
  contactId              String?         // FK to Contact — fully linked in M3
  campaignId             String?
  formId                 String?
  amount                 Float
  currency               String          @default("USD")
  status                 DonationStatus  @default(PENDING)
  type                   DonationType    @default(ONE_TIME)
  paymentMethod          PaymentMethod?
  gateway                PaymentGateway?
  stripeSessionId        String?         @unique
  stripeSubscriptionId   String?
  isRecurring            Boolean         @default(false)
  frequency              String?
  donorName              String
  donorEmail             String
  message                String?
  isAnonymous            Boolean         @default(false)
  tributeId              String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  form           DonationForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  tribute        DonorTribute? @relation("DonationTribute", fields: [tributeId], references: [id], onDelete: SetNull)
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  payments       Payment[]
  giftMatches    GiftMatch[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([formId])
  @@index([donorEmail])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  slug           String         @unique
  description    String?
  type           CampaignType   @default(DONATION)
  status         CampaignStatus @default(DRAFT)
  goalAmount     Float?
  raisedAmount   Float          @default(0)
  startDate      DateTime?
  endDate        DateTime?
  imageUrl       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donations       Donation[]
  donationForms   DonationForm[]
  fundraisingPages FundraisingPage[]
  events          Event[]

  @@index([organizationId])
  @@index([slug])
  @@index([status])
}

model DonationForm {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String    @unique
  fields         Json      // Array<{ id, type, label, required, options? }>
  isPublished    Boolean   @default(false)
  campaignId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  donations    Donation[]

  @@index([organizationId])
  @@index([slug])
  @@index([campaignId])
}

model Event {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  slug           String    @unique
  description    String?
  type           EventType @default(IN_PERSON)
  location       String?
  virtualUrl     String?
  imageUrl       String?
  startDate      DateTime
  endDate        DateTime?
  isPublished    Boolean   @default(false)
  maxCapacity    Int?
  campaignId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign          Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ticketTypes       TicketType[]
  registrations     EventRegistration[]

  @@index([organizationId])
  @@index([slug])
  @@index([startDate])
  @@index([campaignId])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Float    @default(0)
  quantity    Int?
  sold        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([eventId])
}

model EventRegistration {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String
  ticketTypeId   String?
  attendeeName   String
  attendeeEmail  String
  quantity       Int      @default(1)
  totalPaid      Float    @default(0)
  qrCode         String   @unique @default(cuid())
  checkedIn      Boolean  @default(false)
  checkedInAt    DateTime?
  stripeSessionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType   TicketType?  @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([eventId])
  @@index([attendeeEmail])
  @@index([qrCode])
}

// ── Sponsorship domain models ─────────────────────────────────────────────────

model Program {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  goalAmount     Float?
  childCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  children     Child[]

  @@index([organizationId])
}

model School {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  type           SchoolType @default(PRIMARY)
  location       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  children         Child[]
  teacherProfiles  TeacherProfile[]

  @@index([organizationId])
}

model Child {
  id              String    @id @default(cuid())
  organizationId  String
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          String?
  bio             String?
  profileImageUrl String?
  programId       String?
  schoolId        String?
  isAvailable     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program         Program?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  school          School?            @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  sponsorships    Sponsorship[]
  childUpdates    ChildUpdate[]
  childDocuments  ChildDocument[]
  healthRecords   ChildHealthRecord[]
  progress        StudentProgress[]
  waitlistEntries SponsorWaitlist[]
  auditLogs       ChildAuditLog[]

  @@index([organizationId])
  @@index([programId])
  @@index([schoolId])
  @@index([isAvailable])
}

model Sponsorship {
  id                   String            @id @default(cuid())
  organizationId       String
  userId               String
  childId              String
  status               SponsorshipStatus @default(ACTIVE)
  stripeSubscriptionId String?
  monthlyAmount        Float
  startDate            DateTime          @default(now())
  endDate              DateTime?
  pausedAt             DateTime?
  churnScore           Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id])
  child        Child           @relation(fields: [childId], references: [id])
  letters      Letter[]
  messages     SponsorMessage[]

  @@index([organizationId])
  @@index([userId])
  @@index([childId])
  @@index([status])
}

model Letter {
  id             String          @id @default(cuid())
  organizationId String
  sponsorshipId  String
  direction      LetterDirection
  status         LetterStatus    @default(DRAFT)
  subject        String
  body           String
  attachmentUrl  String?
  moderatedBy    String?
  moderatedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsorship  Sponsorship  @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([sponsorshipId])
  @@index([status])
}

model SponsorMessage {
  id             String   @id @default(cuid())
  organizationId String
  sponsorshipId  String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsorship  Sponsorship  @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([sponsorshipId])
}

model ChildUpdate {
  id             String          @id @default(cuid())
  organizationId String
  childId        String
  type           ChildUpdateType @default(GENERAL)
  title          String
  body           String
  imageUrl       String?
  updatedBy      String
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([childId])
}

model ChildDocument {
  id             String            @id @default(cuid())
  organizationId String
  childId        String
  type           ChildDocumentType @default(OTHER)
  name           String
  url            String
  uploadedBy     String
  uploadedAt     DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([childId])
}

model ChildHealthRecord {
  id             String    @id @default(cuid())
  organizationId String
  childId        String
  recordedAt     DateTime  @default(now())
  weight         Float?
  height         Float?
  notes          String?
  createdBy      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([childId])
}

model AcademicTerm {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime  @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  progress     StudentProgress[]

  @@index([organizationId])
}

model StudentProgress {
  id               String         @id @default(cuid())
  organizationId   String
  childId          String
  termId           String
  teacherProfileId String
  subjects         Json
  attendance       Int?
  grade            String?
  notes            String?
  status           ProgressStatus @default(SUBMITTED)
  submittedAt      DateTime       @default(now())
  reviewedAt       DateTime?

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child          Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  term           AcademicTerm   @relation(fields: [termId], references: [id])
  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id])

  @@index([organizationId])
  @@index([childId])
  @@index([termId])
  @@index([teacherProfileId])
}

model TeacherProfile {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  schoolId       String?
  subjects       String[]
  bio            String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id])
  school       School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  progress     StudentProgress[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([schoolId])
}

model SponsorWaitlist {
  id             String   @id @default(cuid())
  organizationId String
  childId        String
  userId         String?
  email          String
  position       Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([childId])
}

model ChildAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  childId        String
  userId         String
  action         String
  details        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([childId])
  @@index([userId])
}

model Tag {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  color          String      @default("#6b7280")
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactTags  ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ContactTag {
  id        String   @id @default(cuid())
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String
  content        String
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
}

model ContactActivity {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String
  type           String
  description    String
  metadata       Json?
  actorId        String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([createdAt])
}

model Segment {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  filters        Json
  contactCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailCampaigns EmailCampaign[]

  @@index([organizationId])
}

model EmailPreference {
  id               String    @id @default(cuid())
  contactId        String    @unique
  organizationId   String
  unsubscribed     Boolean   @default(false)
  unsubscribedAt   DateTime?
  bounced          Boolean   @default(false)
  updatedAt        DateTime  @updatedAt

  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model EmailCampaign {
  id               String              @id @default(cuid())
  organizationId   String
  name             String
  subject          String
  previewText      String?
  blocks           Json
  segmentId        String?
  status           EmailCampaignStatus @default(DRAFT)
  scheduledAt      DateTime?
  sentAt           DateTime?
  totalRecipients  Int                 @default(0)
  totalSent        Int                 @default(0)
  totalOpened      Int                 @default(0)
  totalClicked     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  segment      Segment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  emailSends   EmailSend[]
  emailLogs    EmailLog[]

  @@index([organizationId])
  @@index([status])
  @@index([segmentId])
}

model EmailSend {
  id             String          @id @default(cuid())
  organizationId String
  campaignId     String
  contactId      String
  resendId       String?
  status         EmailSendStatus @default(QUEUED)
  sentAt         DateTime?
  openedAt       DateTime?
  createdAt      DateTime        @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@index([contactId])
}

model EmailLog {
  id             String    @id @default(cuid())
  organizationId String
  campaignId     String?
  contactId      String?
  toEmail        String
  subject        String
  template       String?
  status         String
  resendId       String?
  error          String?
  createdAt      DateTime  @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([campaignId])
}

model Subscriber {
  id               String           @id @default(cuid())
  organizationId   String
  email            String
  firstName        String?
  lastName         String?
  status           SubscriberStatus @default(ACTIVE)
  unsubscribeToken String           @unique @default(cuid())
  subscribedAt     DateTime         @default(now())
  unsubscribedAt   DateTime?
  createdAt        DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  message        String
  metadata       Json?
  read           Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model MilestoneNotification {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String
  milestone      String
  achievedAt     DateTime
  notifiedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, milestone])
  @@index([organizationId])
  @@index([contactId])
}

model Payment {
  id                    String         @id @default(cuid())
  organizationId        String
  donationId            String
  amount                Float
  currency              String         @default("USD")
  gateway               PaymentGateway
  status                PaymentStatus  @default(PENDING)
  gatewayTransactionId  String?        @unique
  gatewayReferenceId    String?
  metadata              Json?
  processedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donation     Donation     @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([donationId])
  @@index([gatewayTransactionId])
}

