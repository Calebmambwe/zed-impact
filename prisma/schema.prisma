// ZedImpact — Prisma Schema
// Multi-tenant nonprofit management platform

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ══════════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════════

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// Donation & Payment enums
enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum DonationType {
  ONE_TIME
  RECURRING
  IN_KIND
  MATCHING
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  CHECK
  CASH
  OTHER
}

enum PaymentGateway {
  STRIPE
  DPO_GROUP
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum CampaignType {
  DONATION
  EVENT
  RAFFLE
  AUCTION
  P2P
  MEMBERSHIP
  EMERGENCY
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ══════════════════════════════════════════════════════════════════
// TENANCY & USERS
// ══════════════════════════════════════════════════════════════════

model Organization {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  description      String?
  logoUrl          String?
  website          String?
  planTier         PlanTier      @default(FREE)
  stripeAccountId  String?
  stripeCustomerId String?
  clerkOrgId       String?       @unique
  customDomain     String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  members       OrgMember[]
  apiKeys       OrgApiKey[]
  customDomains CustomDomain[]
  featureFlags  FeatureFlag[]
  auditLogs     AuditLog[]

  // Stub relations for future milestones
  contacts        Contact[]
  donations       Donation[]
  campaigns       Campaign[]
  donationForms   DonationForm[]
  events          Event[]
  children        Child[]
  sponsorships    Sponsorship[]
  tags            Tag[]
  notes           Note[]
  segments        Segment[]
  emailCampaigns  EmailCampaign[]
  payments        Payment[]
  products        Product[]
  orders          Order[]
  membershipTiers MembershipTier[]
  memberships     Membership[]
  p2pFundraisers  P2PFundraiser[]
  raffleBundles   RaffleBundle[]
  auctionItems    AuctionItem[]
  donorTributes   DonorTribute[]
  giftMatches     GiftMatch[]
  fundraisingPages FundraisingPage[]
  staffTasks      StaffTask[]
  buildingProjects BuildingProject[]
  budgets         Budget[]
  impactReports   ImpactReport[]
}

model User {
  id               String     @id @default(cuid())
  clerkId          String     @unique
  email            String     @unique
  name             String?
  avatarUrl        String?
  role             Role       @default(USER)
  stripeCustomerId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orgMemberships OrgMember[]
  auditLogs      AuditLog[]
}

model OrgMember {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole   @default(STAFF)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrgApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CustomDomain {
  id             String    @id @default(cuid())
  organizationId String
  domain         String    @unique
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  enabled        Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════════
// STUB MODELS — Future milestones extend these
// Each has the minimum fields required for the tenant middleware.
// ══════════════════════════════════════════════════════════════════

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Donation {
  id                     String          @id @default(cuid())
  organizationId         String
  userId                 String?
  contactId              String?         // FK to Contact — fully linked in M3
  campaignId             String?
  formId                 String?
  amount                 Float
  currency               String          @default("USD")
  status                 DonationStatus  @default(PENDING)
  type                   DonationType    @default(ONE_TIME)
  paymentMethod          PaymentMethod?
  gateway                PaymentGateway?
  stripeSessionId        String?         @unique
  stripeSubscriptionId   String?
  isRecurring            Boolean         @default(false)
  frequency              String?
  donorName              String
  donorEmail             String
  message                String?
  isAnonymous            Boolean         @default(false)
  tributeId              String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  form           DonationForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  tribute        DonorTribute? @relation("DonationTribute", fields: [tributeId], references: [id], onDelete: SetNull)
  payments       Payment[]
  giftMatches    GiftMatch[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([formId])
  @@index([donorEmail])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  slug           String         @unique
  description    String?
  type           CampaignType   @default(DONATION)
  status         CampaignStatus @default(DRAFT)
  goalAmount     Float?
  raisedAmount   Float          @default(0)
  startDate      DateTime?
  endDate        DateTime?
  imageUrl       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donations       Donation[]
  donationForms   DonationForm[]
  fundraisingPages FundraisingPage[]

  @@index([organizationId])
  @@index([slug])
  @@index([status])
}

model DonationForm {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String    @unique
  fields         Json      // Array<{ id, type, label, required, options? }>
  isPublished    Boolean   @default(false)
  campaignId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  donations    Donation[]

  @@index([organizationId])
  @@index([slug])
  @@index([campaignId])
}

model Event {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Child {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Sponsorship {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Segment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model EmailCampaign {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

model Payment {
  id                    String         @id @default(cuid())
  organizationId        String
  donationId            String
  amount                Float
  currency              String         @default("USD")
  gateway               PaymentGateway
  status                PaymentStatus  @default(PENDING)
  gatewayTransactionId  String?        @unique
  gatewayReferenceId    String?
  metadata              Json?
  processedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donation     Donation     @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([donationId])
  @@index([gatewayTransactionId])
}

// ══════════════════════════════════════════════════════════════════
// DONATION SUPPLEMENTARY MODELS (M2)
// ══════════════════════════════════════════════════════════════════

model DonorTribute {
  id                String    @id @default(cuid())
  organizationId    String
  tributeType       String    // "in_honor" | "in_memory"
  tributeeName      String
  notificationEmail String?
  message           String?
  createdAt         DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donations    Donation[]    @relation("DonationTribute")

  @@index([organizationId])
}

model GiftMatch {
  id             String    @id @default(cuid())
  organizationId String
  donationId     String
  matchedBy      String
  matchAmount    Float
  matchedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donation     Donation     @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([donationId])
}

model FundraisingPage {
  id             String    @id @default(cuid())
  organizationId String
  campaignId     String
  userId         String
  slug           String    @unique
  title          String
  description    String?
  goalAmount     Float?
  raisedAmount   Float     @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@index([slug])
}

// ══════════════════════════════════════════════════════════════════
// FUTURE MILESTONE STUBS (unchanged)
// ══════════════════════════════════════════════════════════════════

model Product {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId])
}

